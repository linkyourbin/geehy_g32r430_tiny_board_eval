                            <name>BDRST</name>
                            <description>Reset the bkup area</description>
                            <bitOffset>15</bitOffset>
                            <bitWidth>1</bitWidth>
                            <access>read-write</access>
                        </field>


                    </fields>
                </register>
                <register>
