                <offset>0x0</offset>
                <size>0x30</size>
                <usage>registers</usage>
            </addressBlock>
            <interrupt>
                <name>PVD</name>
                <description>PVD through EINT16 Line detection Interrupt</description>
                <value>31</value>
            </interrupt>
            <interrupt>
                <name>EVS</name>
                <description>Main Power Wake-up Interrupt</description>
                <value>33</value>
            </interrupt>


            <registers>
                <register>
                    <name>CR</name>
                    <displayName>CR</displayName>
                    <description>Control Register</description>
                    <addressOffset>0x0</addressOffset>
                    <size>0x20</size>
