                        <field>
                            <name>OFFSET0</name>
                            <description>The data offset compensation corresponding to the channel (single-ended mode INP&lt;0>/differential mode&lt;0>) These bits are written by software, used to define the offset subtracted from the original conversion data when converting the channel (can be regular channel or injection channel) Note: Writing to these bits through software is only allowed when ADSTART=0 and JADSTART=0 (this ensures that no conversion is currently taking place).</description>
                            <bitOffset>0</bitOffset>
                            <bitWidth>16</bitWidth>
                        </field>
                        <field>
                            <name>OFFSET0_EN</name>
                            <description>This bit is enabled and disabled by software writing for programming into the OFFSET0 bit. Note: Writing to this bit through software is only allowed when ADSTART=0 and JADSTART=0 (this ensures that no conversion is currently taking place).</description>
                            <bitOffset>16</bitOffset>
                            <bitWidth>1</bitWidth>
                        </field>
